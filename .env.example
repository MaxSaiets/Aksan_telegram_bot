# ── Telegram ─────────────────────────────────────────────────────────────────
# Отримати токен у @BotFather (https://t.me/BotFather → /newbot)
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Telegram chat ID групи або каналу, куди надсилати оброблені відео.
# Для груп: від'ємне число, наприклад -1001234567890
# Для каналів: від'ємне число або @username
TELEGRAM_TARGET_CHAT_ID=-1001234567890

# Публічна URL вашого сервера (без trailing slash)
# Webhook буде зареєстровано за адресою: TELEGRAM_WEBHOOK_URL/webhook
TELEGRAM_WEBHOOK_URL=https://yourdomain.com

# Секретний рядок для верифікації вебхук-запитів від Telegram.
# Будь-який рандомний рядок 1-256 символів [A-Za-z0-9_-]
TELEGRAM_WEBHOOK_SECRET=your_random_secret_string_here

# Telegram user ID (через кому) тих, хто може використовувати бота.
# Залиш порожнім — доступ для всіх.
# Знайти свій ID: напишіть @userinfobot в Telegram.
TELEGRAM_ALLOWED_USERS=

# ── YouTube ───────────────────────────────────────────────────────────────────
YOUTUBE_CHANNEL_ID=UCxxxxxxxxxxxxxxxx
# Шлях до JSON-файлу OAuth2 credentials (з Google Cloud Console)
YOUTUBE_CLIENT_SECRETS_FILE=client_secrets.json

# ── Supabase ─────────────────────────────────────────────────────────────────
SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── SalesDrive CRM ───────────────────────────────────────────────────────────
SALESDRIVE_API_URL=https://YOUR_DOMAIN.salesdrive.me
SALESDRIVE_API_KEY=YOUR_SALESDRIVE_API_KEY

# ── Rozetka ───────────────────────────────────────────────────────────────────
ROZETKA_SELLER_ID=YOUR_SELLER_ID
ROZETKA_API_KEY=YOUR_ROZETKA_API_KEY

# ── Supabase Storage ──────────────────────────────────────────────────────────
# Створити в Supabase Dashboard → Storage → New bucket → Public: ON
SUPABASE_STORAGE_BUCKET=processed-videos

# ── App ───────────────────────────────────────────────────────────────────────
# true  → всі зовнішні сервіси імітуються (для розробки/тестування)
# false → реальні API виклики
USE_MOCKS=true
TEMP_VIDEO_DIR=tmp/videos
LOG_LEVEL=INFO
